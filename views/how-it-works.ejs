<%- include('partials/header') %>

<div class="container" style="padding-top: 4rem; padding-bottom: 4rem; text-align: center; max-width: 800px;">
  <h1 style="color: var(--primary-color); margin-bottom: 1rem;">How It Works</h1>
  <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 3rem;">Getting your job sorted is simple and fast with Ringatrade.</p>

  <div style="display: flex; flex-direction: column; gap: 2rem; text-align: left;">
    <div style="background: var(--bg-white); padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); display: flex; gap: 1.5rem; align-items: center;">
      <div style="background: var(--primary-color); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 800; flex-shrink: 0;">1</div>
      <div>
        <h3 style="color: var(--text-main); margin-bottom: 0.5rem;">Tell us the job</h3>
        <p style="color: var(--text-muted);">Fill out our simple form with your postcode, what trade you need, and a quick description of the problem. It takes less than a minute.</p>
      </div>
    </div>

    <div style="background: var(--bg-white); padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); display: flex; gap: 1.5rem; align-items: center;">
      <div style="background: var(--primary-color); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 800; flex-shrink: 0;">2</div>
      <div>
        <h3 style="color: var(--text-main); margin-bottom: 0.5rem;">We review and match it</h3>
        <p style="color: var(--text-muted);">Our system quickly reviews your request and securely sends the details to trusted, local tradespeople who cover your area.</p>
      </div>
    </div>

    <div style="background: var(--bg-white); padding: 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); display: flex; gap: 1.5rem; align-items: center;">
      <div style="background: var(--primary-color); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 800; flex-shrink: 0;">3</div>
      <div>
        <h3 style="color: var(--text-main); margin-bottom: 0.5rem;">A suitable tradesperson contacts you</h3>
        <p style="color: var(--text-muted);">A local professional will reach out via your preferred contact method to discuss the job, give you a quote, or arrange a visit.</p>
      </div>
    </div>
  </div>

  <div style="margin-top: 4rem;">
    <a href="/post-job" class="btn btn-primary" style="font-size: 1.2rem; padding: 1rem 2.5rem;">Post a Job Now</a>
  </div>
</div>

<%- include('partials/footer') %>
