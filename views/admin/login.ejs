<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Ringatrade</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: var(--bg-light); display: flex; align-items: center; justify-content: center; height: 100vh;">
  <div class="form-container" style="width: 100%; max-width: 400px; margin: 0;">
    <h1 class="text-center mb-2" style="color: var(--primary-color);">Admin Login</h1>
    
    <% if (error) { %>
      <div style="background-color: #fee2e2; color: #991b1b; padding: 1rem; border-radius: var(--radius); margin-bottom: 1.5rem; text-align: center;">
        <%= error %>
      </div>
    <% } %>
    
    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" class="form-control" required>
      </div>
      
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" required>
      </div>
      
      <button type="submit" class="btn btn-primary btn-block">Login</button>
    </form>
    
    <div class="text-center mt-2">
      <a href="/" style="color: var(--text-muted); text-decoration: none;">&larr; Back to main site</a>
    </div>
  </div>
</body>
</html>
