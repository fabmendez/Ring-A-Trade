<%- include('partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <h1>Dashboard Overview</h1>
  <a href="/" target="_blank" class="btn btn-secondary" style="padding: 0.5rem 1rem;">View Live Site &rarr;</a>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <h4>Total Leads</h4>
    <div class="value"><%= stats.totalLeads %></div>
  </div>
  <div class="stat-card">
    <h4>New</h4>
    <div class="value" style="color: #1e3a8a;"><%= stats.newLeads %></div>
  </div>
  <div class="stat-card">
    <h4>Qualified</h4>
    <div class="value" style="color: #854d0e;"><%= stats.qualifiedLeads %></div>
  </div>
  <div class="stat-card">
    <h4>Sent</h4>
    <div class="value" style="color: #3730a3;"><%= stats.sentLeads %></div>
  </div>
  <div class="stat-card">
    <h4>Won</h4>
    <div class="value" style="color: #166534;"><%= stats.wonLeads %></div>
  </div>
  <div class="stat-card">
    <h4>Lost</h4>
    <div class="value" style="color: #991b1b;"><%= stats.lostLeads %></div>
  </div>
</div>

<div style="background: white; padding: 1.5rem; border-radius: var(--radius); box-shadow: var(--shadow-sm);">
  <h2 style="margin-bottom: 1.5rem;">Recent Leads</h2>
  
  <% if (leads.length === 0) { %>
    <p style="color: var(--text-muted);">No leads yet.</p>
  <% } else { %>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Date</th>
            <th>Trade</th>
            <th>Postcode</th>
            <th>Customer Name</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% leads.forEach(lead => { %>
            <tr>
              <td>#<%= lead.id %></td>
              <td><%= new Date(lead.created_at).toLocaleDateString() %></td>
              <td><strong><%= lead.trade %></strong></td>
              <td><%= lead.postcode %></td>
              <td><%= lead.customer_name %></td>
              <td>
                <% 
                  let badgeClass = 'badge-new';
                  if (lead.status === 'Qualified') badgeClass = 'badge-qualified';
                  if (lead.status === 'Sent to Tradesperson' || lead.status === 'Voice Call Started') badgeClass = 'badge-sent';
                  if (lead.status === 'Won') badgeClass = 'badge-won';
                  if (lead.status === 'Lost' || lead.status === 'Rejected by Tradesperson') badgeClass = 'badge-lost';
                %>
                <span class="badge <%= badgeClass %>"><%= lead.status %></span>
              </td>
              <td>
                <a href="/admin/leads/<%= lead.id %>" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
