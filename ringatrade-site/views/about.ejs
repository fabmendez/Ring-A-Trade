<%- include('partials/header') %>

<main>
  <!-- Hero -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero-inner">
        <h1>About Ringatrade</h1>
        <p class="about-hero-sub">Helping people connect with local tradespeople more simply.</p>
      </div>
    </div>
  </section>

  <section class="page-main">
    <div class="container container-md">

      <!-- Intro -->
      <div class="about-intro">
        <p>Ringatrade was built to make finding local tradespeople less stressful, less time-consuming, and more straightforward.</p>
        <p>Instead of endless searching, repeated phone calls, or confusing directories, Ringatrade helps people describe a job once and connect with suitable local tradespeople quickly and simply.</p>
      </div>

      <!-- Sections -->
      <div class="about-sections">

        <div class="about-card">
          <div class="about-card-icon">🔧</div>
          <div class="about-card-body">
            <h2>What We Do</h2>
            <p>Ringatrade helps homeowners and businesses post jobs and connect with local tradespeople covering a wide range of services including plumbing, electrical work, roofing, decorating, gardening, heating, and more.</p>
          </div>
        </div>

        <div class="about-card">
          <div class="about-card-icon">🎯</div>
          <div class="about-card-body">
            <h2>Our Approach</h2>
            <p>We focus on simplicity, speed, and clear communication. Our goal is to make it easier for customers to explain what they need while helping tradespeople discover relevant local work opportunities.</p>
          </div>
        </div>

        <div class="about-card">
          <div class="about-card-icon">💡</div>
          <div class="about-card-body">
            <h2>Technology</h2>
            <p>Ringatrade uses modern technology to help organise job requests, improve communication, and streamline the matching process between customers and tradespeople.</p>
          </div>
        </div>

      </div>

      <!-- CTA -->
      <div class="about-cta">
        <h2>Need help with a job?</h2>
        <p>Post your job for free and we'll help connect you with a suitable local tradesperson.</p>
        <a href="/post-a-job" class="btn btn-primary btn-lg">Post a Job</a>
      </div>

    </div>
  </section>
</main>

<%- include('partials/footer') %>
