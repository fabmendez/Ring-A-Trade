<%- include('partials/header') %>

<main class="page-main">
  <div class="container container-narrow">
    <div class="page-header centered">
      <h1>Contact Us</h1>
      <p>Have a question? Get in touch and we'll get back to you as soon as we can.</p>
    </div>

    <% if (success) { %>
      <div class="form-card">
        <div class="success-message">
          <div class="success-icon">✅</div>
          <h2>Message received!</h2>
          <p>Thanks for getting in touch. We'll get back to you soon.</p>
          <a href="/" class="btn btn-primary">Back to Home</a>
        </div>
      </div>
    <% } else { %>
      <div class="form-card">
        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-error">
            <ul>
              <% errors.forEach(err => { %>
                <li><%= err %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <form action="/contact" method="POST" class="form">
          <div class="form-group">
            <label for="name" class="form-label">Your Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" class="form-control" value="<%= old.name || '' %>" required />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email Address <span class="required">*</span></label>
            <input type="email" id="email" name="email" class="form-control" value="<%= old.email || '' %>" required />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Message <span class="required">*</span></label>
            <textarea id="message" name="message" class="form-control" rows="6" required><%= old.message || '' %></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg btn-full">Send Message</button>
        </form>
      </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
